### Computed flags (replicate in the mobile app for the detail screen)

```kotlin
data class SummaryViewState(
    val isSectionDraft: Boolean,
    val isInCurrentDepartment: Boolean,
    val isCurrentHolder: Boolean,
    val isCurrentSecretaryHolder: Boolean,
    val isOriginatingDepartment: Boolean,
    val isDraftReturnedToMe: Boolean,
    val myInternalForward: SummaryInternalForward?,
    val visibleInternalForwards: List<SummaryInternalForward>,
    val visibleInternalFiles: List<SummaryInternalFile>,
    val localLinks: List<SummaryLocalLink>,
    val canPrintRemarks: Boolean,
    val hasUnsignedDeptRemarks: Boolean,
    val showDraftActions: Boolean
) {
    companion object {
        fun build(summary: Summary, me: UserDesg, myDeptId: Long, myDeptUserDesgIds: Set<Long>): SummaryViewState {
            val isSectionDraft = summary.summaryType == SummaryType.SectionDraft
            val isInCurrentDepartment = summary.currentDepartmentId == myDeptId
            val isCurrentHolder = isInCurrentDepartment && summary.currentHolderUserDesgId == me.id
            val isCurrentSecretaryHolder = isCurrentHolder && me.isSecretaryOrActing(myDeptId)
            val isOriginatingDepartment = summary.originatingDepartmentId == myDeptId

            val latestReturnToMe = if (isCurrentHolder && !isCurrentSecretaryHolder) {
                summary.movements
                    .filter { it.actionType == MovementAction.ReturnedToSection && it.toUserDesgId == me.id }
                    .maxByOrNull { it.actedAt }
            } else null

            val isDraftReturnedToMe = isCurrentHolder && !isCurrentSecretaryHolder && latestReturnToMe != null

            val myInternalForward = summary.internalForwards
                .firstOrNull { it.forwardedToUserDesgId == me.id && it.status == 1 }

            val visibleInternalForwards = summary.internalForwards.filter { fwd ->
                /* by-dept or to-dept matches myDept */
                /* server already filters; mobile re-filters defensively */
                true
            }

            val hasUnsignedDeptRemarks = summary.movements.any {
                it.actionType == MovementAction.RemarksAdded
                && it.secretarySignaturePath.isNullOrEmpty()
                && it.fromDepartmentId == myDeptId
            }

            val showDraftActions = (isSectionDraft && isOriginatingDepartment && isCurrentSecretaryHolder)
                || (isCurrentSecretaryHolder && hasUnsignedDeptRemarks)

            val localLinks = summary.localLinks.filter { it.linkedByUserDesgId in myDeptUserDesgIds }

            // ... etc
        }
    }
}
```

